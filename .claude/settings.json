{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(mvn:*)",
      "Bash(mvn clean:*)",
      "Bash(mvn test:*)",
      "Bash(mvn package:*)",
      "Bash(mvnw:*)",
      "WebFetch(domain:docs.spring.io)"
    ]
  },
  "model": "opus",
  "enabledPlugins": {
    "revdiff@revdiff": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "revdiff": {
      "source": {
        "source": "github",
        "repo": "umputun/revdiff"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  }
}
